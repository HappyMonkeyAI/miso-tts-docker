# miso-tts-docker — https://github.com/YOUR_USER/miso-tts-docker
#
# Required for the gated Llama 3.2 tokenizer used by MisoTTS.
# 1. Create a token at https://huggingface.co/settings/tokens (Read access is enough)
# 2. Log into Hugging Face and accept the license at:
#    https://huggingface.co/meta-llama/Llama-3.2-1B
# 3. Verify with: check-access.cmd
HF_TOKEN=hf_your_token_here

# Full-precision model (recommended for 24 GB RTX 5090)
MISO_TTS_8B_MODEL=MisoLabs/MisoTTS

# Optional: INT4 quantized model for lower VRAM (~11-12 GB)
# MISO_TTS_8B_MODEL=droyster/MisoTTS-8B-torchao-int4