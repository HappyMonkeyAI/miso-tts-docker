# miso-tts-docker — https://github.com/YOUR_USER/miso-tts-docker
#
# Required for the gated Llama 3.2 tokenizer used by MisoTTS.
# 1. Create a token at https://huggingface.co/settings/tokens (Read access is enough)
# 2. Log into Hugging Face and accept the license at:
#    https://huggingface.co/meta-llama/Llama-3.2-1B
# 3. Verify with: check-access.cmd
HF_TOKEN=hf_your_token_here

# Full-precision model (recommended for 24 GB RTX 5090)
MISO_TTS_8B_MODEL=MisoLabs/MisoTTS

# Optional: INT4 quantized model for lower VRAM (~11-12 GB)
# MISO_TTS_8B_MODEL=droyster/MisoTTS-8B-torchao-int4

# --- Web conversational demo ---
WEB_PORT=8000
WEB_HTTPS_PORT=8443
MISO_API_PORT=8080
POCKET_API_PORT=8090

# LAN IP for HTTPS dev cert + mic access from phones/tablets on your network
# Regenerate after changing: scripts\gen-dev-certs.cmd --force
DEV_CERT_IP=192.168.5.157
# Optional machine hostname (DNS SAN on the same cert)
# DEV_CERT_HOSTNAME=my-pc.local

# TTS engine default for new sessions: pocket (fast, CPU) or miso (quality, GPU)
TTS_BACKEND=pocket

# Web container → TTS APIs (default: same Docker network)
MISO_API_URL=http://miso-api:8080
POCKET_API_URL=http://pocket-api:8090

# To host web on another machine, point at your GPU host:
# MISO_API_URL=http://192.168.1.50:8080

# LLM for reply text (OpenRouter, LM Studio, Ollama OpenAI shim, etc.)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL_NAME=google/gemma-2-9b-it:free

# LM Studio (local) — use /v1 not /api/v1; enable OpenAI-compatible server on port 1234
# LLM_BASE_URL=http://host.docker.internal:1234/v1
# LLM_API_KEY=dummy-key
# LLM_MODEL_NAME=your-lm-studio-model-id
# Qwen reasoning models need enable_thinking=false (handled automatically by the web app)

# Speech-to-text (Whisper runs on CPU inside the web container)
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8