# miso-tts-docker — https://github.com/YOUR_USER/miso-tts-docker
#
# Required for the gated Llama 3.2 tokenizer used by MisoTTS.
# 1. Create a token at https://huggingface.co/settings/tokens (Read access is enough)
# 2. Log into Hugging Face and accept the license at:
#    https://huggingface.co/meta-llama/Llama-3.2-1B
# 3. Verify with: check-access.cmd
HF_TOKEN=hf_your_token_here

# Full-precision model (recommended for 24 GB RTX 5090)
MISO_TTS_8B_MODEL=MisoLabs/MisoTTS

# Optional: INT4 quantized model for lower VRAM (~11-12 GB)
# MISO_TTS_8B_MODEL=droyster/MisoTTS-8B-torchao-int4

# --- Web conversational demo ---
WEB_PORT=8000
MISO_API_PORT=8080

# Web container → GPU API (default: same Docker network)
MISO_API_URL=http://miso-api:8080

# To host web on another machine, point at your GPU host:
# MISO_API_URL=http://192.168.1.50:8080

# LLM for reply text (OpenRouter, LM Studio, Ollama OpenAI shim, etc.)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL_NAME=google/gemma-2-9b-it:free

# Speech-to-text (Whisper runs on CPU inside the web container)
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8